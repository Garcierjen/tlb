{
  "compilerOptions": {
    /* Basic Options */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "types": ["bun-types"],
    
    /* Output Options */
    "outDir": "./public/dist",
    "rootDir": "./",
    "noEmit": false, // อนุญาตให้ tsc ออกไฟล์ (หรือใช้ bun build แทนก็ได้)
    
    /* Strict Checks */
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    
    /* Module Interop */
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    
    /* Advanced */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true
  },
  "include": [
    "api/**/*",     // รวมไฟล์ Backend (Elysia)
    "public/**/*.ts" // รวมไฟล์ Frontend (TypeScript)
, "api/index.ts"  ],
  "exclude": [
    "node_modules",
    "public/dist"
  ]
}
